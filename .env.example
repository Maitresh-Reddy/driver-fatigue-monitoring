# ============================================================================
# EMERGENCY ALERT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill with your own values.
# DO NOT COMMIT .env TO GIT - it's already in .gitignore for your safety.
#
# To enable critical driver state alerts via email:
# 1) Fill all "EMERGENCY_SMTP_*" fields (Gmail example below)
# 2) Fill "EMERGENCY_TO_EMAIL" with recipient address
# 3) Set "EMERGENCY_EMAIL_ENABLED=true"
# 4) Restart the app
#
# For Gmail:
#   - Enable 2-Step Verification: https://myaccount.google.com/security
#   - Create an App Password: https://myaccount.google.com/apppasswords
#   - Use App Password (16 chars) in EMERGENCY_SMTP_PASSWORD below
# ============================================================================

# Enable/disable the entire emergency alert system
EMERGENCY_EMAIL_ENABLED=true

# ===== SMTP Configuration (Gmail example) =====
EMERGENCY_SMTP_SERVER=smtp.gmail.com
EMERGENCY_SMTP_PORT=587
EMERGENCY_SMTP_USE_TLS=true
EMERGENCY_SMTP_USERNAME=your_email@gmail.com
EMERGENCY_SMTP_PASSWORD=your_16_character_app_password

# ===== Email Details =====
EMERGENCY_FROM_EMAIL=your_email@gmail.com
EMERGENCY_TO_EMAIL=emergency_contact@example.com
EMERGENCY_EMAIL_SUBJECT_PREFIX=[Driver Monitor Emergency]
EMERGENCY_EMAIL_COOLDOWN_SECONDS=120

# ===== Driver & Vehicle Info =====
EMERGENCY_DRIVER_ID=DRIVER_01
EMERGENCY_VEHICLE_ID=VEHICLE_01

# ===== Location (OPTIONAL) =====
# Leave blank to auto-fetch location (device location on Windows, then IP fallback)
# Or provide exact coordinates:
EMERGENCY_LOCATION_LAT=
EMERGENCY_LOCATION_LON=
EMERGENCY_LOCATION_TEXT=

# Try OS/device location services first (recommended for real-world use)
EMERGENCY_ALLOW_DEVICE_GEOLOCATION=true

# ===== IP Geolocation Fallback (used if coordinates empty) =====
EMERGENCY_ALLOW_IP_GEOLOCATION=true
EMERGENCY_IP_GEOLOCATION_URL=https://ipapi.co/json/
EMERGENCY_HTTP_TIMEOUT_SECONDS=4.0
